# =============================================================================
# 美宜佳门店助手 · 本地开发环境变量模板（单一事实源）
#
# 用法:
#   cp .env.example .env
#   编辑 .env 填入实际密钥（从飞书/OSS/Dify/OpenRouter 控制台获取）
#
# 覆盖范围:
#   - 后端 API (apps/api,通过 dotenv 加载本文件)
#   - 前端 Vite (apps/web,envDir 指向仓库根;只暴露 VITE_* 前缀到 bundle)
#   - 本地 PostgreSQL (docker-compose dev profile)
#
# 生产环境用 .env.production —— 运维在服务器上维护,不入库不出现在 dev 机器
# 生产字段清单见 .env.production.example
# =============================================================================

# ---- 本地 Postgres (docker-compose dev profile 用) ---------------------------
POSTGRES_DB=myj_dev
POSTGRES_USER=myj
POSTGRES_PASSWORD=myj

# ---- 后端服务 ----------------------------------------------------------------
NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# ---- 数据库连接 (后端连本地 postgres 容器) ----------------------------------
DATABASE_URL=postgresql://myj:myj@localhost:5432/myj_dev

# ---- 飞书 OAuth (M1) ---------------------------------------------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:5173/auth/callback

# ---- 会话 (默认 7 天;账密 / 飞书登录共用此 TTL) -----------------------------
SESSION_TTL_SECONDS=604800
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ---- 阿里云 OSS (M2/M4 用,海报底图/货架照片) -------------------------------
OSS_REGION=oss-cn-beijing
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ---- Dify AI 工作流 (M2/M3,密钥仅后端可见,绝不下发前端) -------------------
DIFY_BASE_URL=https://dify.rollingai.cn/v1
DIFY_KEY_SELECTION=
DIFY_KEY_ALIGN=
DIFY_KEY_INSIGHT=
DIFY_KEY_QUESTIONS=
DIFY_KEY_VIRTUAL_SHELF=
DIFY_KEY_PRICE_DIAGNOSE=

# ---- OpenRouter (M4 海报多模态) ---------------------------------------------
OPENROUTER_API_KEY=

# ---- Detect Service (M2 商品识别,独立 Python 微服务) -----------------------
# 仅记录 HTTP 入口;YOLO/PE/OCR 密钥在该服务自己的 .env,见 docs/ops/detect-service.env.example
DETECT_SERVICE_URL=http://localhost:8000

# ---- 前端构建变量 (VITE_ 前缀 = import.meta.env.VITE_*,会烧进 bundle) ------
VITE_API_BASE_URL=http://localhost:8787
