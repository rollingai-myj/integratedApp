# =============================================================================
# 美宜佳门店助手 · 根级环境变量模板
#
# 用法：
#   cp .env.example .env
#   cp apps/api/.env.example apps/api/.env
#   cp apps/web/.env.example apps/web/.env
#
# 这份根 .env 当前只用于 docker-compose；后端 / 前端 各自有自己的 .env。
# =============================================================================

# Postgres（docker-compose 用）
POSTGRES_DB=myj_dev
POSTGRES_USER=myj
POSTGRES_PASSWORD=myj
