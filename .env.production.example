# =============================================================================
# 美宜佳门店助手 · 生产环境变量模板（字段清单,真相源）
#
# 此文件入库,作用是:
#   1. 给运维参考字段清单
#   2. deploy.sh 部署时 comm -23 校验:服务器 .env.production 缺字段则中止
#
# 实际 .env.production 由运维在生产服务器上手工维护:
#   - 仓库 .gitignore 已覆盖,不入库
#   - 不存在于 dev 机器,密钥不流通
#   - 包含真实 RDS 连接串、生产 API key、生产域名
#
# 部署流程见 docs/ops/deployment.md
# =============================================================================

# ---- 服务 -------------------------------------------------------------------
NODE_ENV=production
PORT=8787
LOG_LEVEL=info

# ---- 暴露端口 (nginx 容器在宿主机监听的端口,被边缘 Caddy 反代) -------------
WEB_PORT=8088

# ---- 数据库 (生产 RDS,不是本地 postgres) -----------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@RDS_HOST:5432/myj_prod

# ---- 飞书 OAuth -------------------------------------------------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=https://YOUR_DOMAIN/auth/callback

# ---- 会话 (生产强制 secure cookie) -----------------------------------------
SESSION_TTL_SECONDS=604800
COOKIE_DOMAIN=YOUR_DOMAIN
COOKIE_SECURE=true

# ---- 阿里云 OSS -------------------------------------------------------------
OSS_REGION=oss-cn-beijing
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ---- Dify AI 工作流 ---------------------------------------------------------
DIFY_BASE_URL=https://dify.rollingai.cn/v1
DIFY_KEY_SELECTION=
DIFY_KEY_ALIGN=
DIFY_KEY_INSIGHT=
DIFY_KEY_QUESTIONS=
DIFY_KEY_VIRTUAL_SHELF=
DIFY_KEY_PRICE_DIAGNOSE=

# ---- OpenRouter -------------------------------------------------------------
OPENROUTER_API_KEY=

# ---- Detect Service ---------------------------------------------------------
DETECT_SERVICE_URL=

# ---- 前端构建变量 (build-time,烧进生产 bundle) -----------------------------
# 生产前端通常和 API 同域,经 nginx 反代,所以 base 是空字符串(走相对路径)
VITE_API_BASE_URL=
