# 服务
NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# 数据库
DATABASE_URL=postgresql://myj:myj@localhost:5432/myj_dev

# 飞书（M1 用）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:5173/auth/callback

# 会话
SESSION_TTL_SECONDS=7200
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# 阿里云 OSS（M2+ 用）
OSS_REGION=oss-cn-shanghai
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Dify（M2+ 用）
DIFY_BASE_URL=https://dify.rollingai.cn/v1
DIFY_KEY_SELECTION=
DIFY_KEY_ALIGN=
DIFY_KEY_INSIGHT=
DIFY_KEY_QUESTIONS=
DIFY_KEY_VIRTUAL_SHELF=
DIFY_KEY_PRICE_DIAGNOSE=

# OpenRouter（M4 用）
OPENROUTER_API_KEY=

# Detect Service（M2 用）
DETECT_SERVICE_URL=http://localhost:8000
